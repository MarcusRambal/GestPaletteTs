{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@app/types": ["./types/types.ts"]
    }
  },
  "include": [
    "src/**/*",
    "types/**/*"
  ]
}
