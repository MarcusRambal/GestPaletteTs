{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@app/types": ["./types/types.ts"]
    }
  },
  "include": [
    "electron/**/*",
    "db/**/*",
    "types/**/*"
  ]
}
